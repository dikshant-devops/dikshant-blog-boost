# Cross-Posting API Keys
# Copy this file to .env and fill in your actual API keys

# Dev.to API
# Get your key: https://dev.to/settings/extensions
DEVTO_API_KEY=

# Medium API
# Get your token: https://medium.com/me/settings/security (Integration tokens section)
MEDIUM_TOKEN=

# LinkedIn API
# Create app: https://www.linkedin.com/developers/apps
# Required scopes: w_member_social, r_liteprofile
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=

# Site Configuration
SITE_URL=https://techwithdikshant.com
SITE_NAME=Tech With Dikshant
AUTHOR_TWITTER=@techwithdikshant

# Public browser key. Use a Cloudflare Turnstile test site key for local development.
VITE_TURNSTILE_SITE_KEY=replace-with-cloudflare-site-key
