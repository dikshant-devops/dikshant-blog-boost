# Contact Form Configuration

# Cloudflare Turnstile (client-side)
# Get your site key from: https://dash.cloudflare.com/?to=/:account/turnstile
VITE_TURNSTILE_SITE_KEY=0x4AAAAAACDOs4z_C487MLjL

# Server-side secrets (set in Cloudflare Pages Dashboard)
# DO NOT commit these values - this file is for documentation only

# SheetDB API endpoint URL
# Get from: https://sheetdb.io after connecting your Google Sheet
# SHEETDB_API_URL=https://sheetdb.io/api/v1/YOUR_ID

# Cloudflare Turnstile secret key
# Get from: https://dash.cloudflare.com/?to=/:account/turnstile
# TURNSTILE_SECRET_KEY=your_secret_key

# Rate limiting configuration
# Maximum requests per IP address in the time window
# RATE_LIMIT_MAX_REQUESTS=5

# Time window in milliseconds (3600000 = 1 hour)
# RATE_LIMIT_WINDOW_MS=3600000
